# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/heapify

# Redis (Use Upstash free tier — get URL from upstash.com)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Groq (Free — get key from console.groq.com)
GROQ_API_KEY=your_groq_api_key

# File Storage (Use Cloudinary free tier)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_key
CLOUDINARY_API_SECRET=your_cloudinary_secret

# Vector DB (Use Chroma self-hosted or Qdrant free cloud)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_key

# Email (Use Brevo/Sendinblue free tier SMTP)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_email
SMTP_PASS=your_smtp_key

# Speech (Use Groq Whisper — already included in Groq key)
GROQ_WHISPER_MODEL=whisper-large-v3

# Embedding (Use Groq or HuggingFace free inference)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
