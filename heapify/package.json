{
  "name": "heapify",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=apps/server\" \"npm run dev --workspace=apps/web\"",
    "build": "npm run build --workspace=apps/web && npm run build --workspace=apps/server"
  },
  "dependencies": {
    "concurrently": "^9.2.1"
  }
}
